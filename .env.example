# Agentic Vision Intelligence Platform — Environment Variables
# Copy to .env and fill in values as needed.

# --- Ollama (local-first, no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI (optional cloud provider) ---
OPENAI_API_KEY=

# --- Google Gemini (optional cloud provider) ---
GEMINI_API_KEY=

# --- Anthropic (optional cloud provider) ---
ANTHROPIC_API_KEY=

# --- YOLO defaults ---
YOLO_CONFIDENCE=0.35

# --- Camera ---
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720

# --- Processing ---
FRAME_SAMPLE_RATE=5
MEMORY_WINDOW_SECONDS=300
EVENT_COOLDOWN_SECONDS=10
LLM_TRIGGER_THRESHOLD=3

# --- Reporting ---
REPORT_OUTPUT_DIR=output

# --- Security ---
# Allow Ollama URL to point at arbitrary hosts. Leave at 0/false for hosted
# deployments — prevents SSRF via the Streamlit sidebar "Ollama URL" input.
# Only set to 1 if you explicitly need to reach an Ollama daemon outside the
# loopback/private IP range (e.g. across a trusted VPN).
ALLOW_REMOTE_OLLAMA=0
